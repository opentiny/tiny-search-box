{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": false,
    "jsx": "preserve",
    "allowJs": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "baseUrl": ".",
    "paths": {
      "@opentiny/vue-search-box": ["../search-box/index.ts"],
      "@opentiny/vue-search-box/*": ["../search-box/*"]
    },
    "types": ["vitepress/client", "node"]
  },
  "include": [
    "**/*.ts",
    "**/*.d.ts",
    "**/*.vue",
    ".vitepress/**/*.ts",
    ".vitepress/**/*.d.ts"
  ],
  "exclude": ["node_modules", ".vitepress/dist", ".vitepress/cache", ".vitepress/.temp"]
}
